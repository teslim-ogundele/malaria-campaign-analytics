-- Database Schema for Integrated SMC-ITN Campaign Tracking

-- 1. Operational Targets Table
CREATE TABLE IF NOT EXISTS campaign_targets (
    settlement_id TEXT PRIMARY KEY,
    state TEXT NOT NULL,
    lga TEXT NOT NULL,
    ward TEXT NOT NULL,
    settlement_name TEXT NOT NULL,
    target_children_3_59m INTEGER NOT NULL,
    target_itn_distributed INTEGER NOT NULL
);

-- 2. Beneficiary Registrations (Frontline Mobile App Ingestion)
CREATE TABLE IF NOT EXISTS beneficiary_registrations (
    registration_id TEXT PRIMARY KEY,
    settlement_id TEXT,
    household_head TEXT NOT NULL,
    child_name TEXT NOT NULL,
    child_age_months INTEGER NOT NULL,
    spaq_administered_cycle1 INTEGER DEFAULT 0, -- 0 = No, 1 = Yes
    itn_delivered INTEGER DEFAULT 0,
    gps_latitude REAL,
    gps_longitude REAL,
    device_id TEXT NOT NULL,
    sync_timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (settlement_id) REFERENCES campaign_targets(settlement_id)
);

-- 3. Field Anomaly & Data Quality Log (For Command Center Action)
CREATE TABLE IF NOT EXISTS data_quality_logs (
    log_id INTEGER PRIMARY KEY AUTOINCREMENT,
    record_id TEXT,
    issue_type TEXT NOT NULL, -- e.g., 'OUT_OF_AGE_RANGE', 'DUPLICATE_REGISTRATION', 'INVALID_GPS'
    severity TEXT NOT NULL,    -- e.g., 'CRITICAL', 'WARNING'
    detected_at DATETIME DEFAULT CURRENT_TIMESTAMP
);
